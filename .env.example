# PostgreSQL (local dev — on Render use DATABASE_URL instead)
POSTGRES_DB=insurecheck
POSTGRES_USER=insurecheck
POSTGRES_PASSWORD=insurecheck_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Or use a single connection string (Render sets this automatically)
# DATABASE_URL=postgresql://insurecheck:insurecheck_secret@localhost:5432/insurecheck

# Django
DJANGO_SECRET_KEY=change-me-in-production-very-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Frontend URL (for CORS — comma-separated for multiple origins)
FRONTEND_URL=http://localhost:3000

# CSRF trusted origins (set to your Render frontend URL in production)
# CSRF_TRUSTED_ORIGINS=https://insurecheck-frontend.onrender.com

# File uploads
MAX_UPLOAD_SIZE_MB=10
MEDIA_ROOT=media/uploads

# Render (set automatically by Render)
# RENDER=true
